    "deploy:preflight": "tsx scripts/deploy-preflight.ts",
    "deploy:vercel": "npx vercel deploy --prod"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "next": "16.2.10",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/prop-types": "15.7.12",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "postcss": "8.5.16",
    "prisma": "6.19.3",
    "tailwindcss": "3.4.4",
    "tsx": "4.20.6",
    "typescript": "5.5.3"
  }
